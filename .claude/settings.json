{
  "permissions": {
    "allow": [
      "Bash(yt-dlp*)",
      "Read(output/youtube-adhoc/**)",
      "Write(output/youtube-adhoc/**)"
    ]
  },
  "mcpServers": {
    "groq": {
      "command": "uvx",
      "args": ["groq-mcp"],
      "env": {
        "GROQ_API_KEY": "${GROQ_API_KEY}"
      }
    }
  }
}
